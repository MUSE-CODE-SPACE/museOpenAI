{
  "data_dir": "data/tinyshakespeare",
  "tokenizer_path": "data/tinyshakespeare/tokenizer.json",
  "batch_size": 32,
  "grad_accum_steps": 1,
  "max_steps": 1500,
  "learning_rate": 0.0006,
  "min_learning_rate": 0.00006,
  "warmup_steps": 100,
  "weight_decay": 0.1,
  "grad_clip": 1.0,
  "eval_interval": 250,
  "eval_steps": 40,
  "log_interval": 25,
  "checkpoint_dir": "checkpoints/tiny",
  "keep_last_checkpoints": 2,
  "device": "auto",
  "seed": 1337,
  "model": {
    "vocab_size": 2048,
    "dim": 256,
    "n_layers": 6,
    "n_heads": 8,
    "n_kv_heads": 4,
    "max_seq_len": 256,
    "ffn_hidden_dim": 704,
    "n_experts": 0,
    "dropout": 0.2,
    "qk_norm": true,
    "tie_embeddings": true
  }
}
