{
  "data_dir": "data/tinyshakespeare",
  "tokenizer_path": "data/tinyshakespeare/tokenizer.json",
  "batch_size": 24,
  "grad_accum_steps": 2,
  "max_steps": 3000,
  "learning_rate": 0.0006,
  "min_learning_rate": 0.00006,
  "warmup_steps": 150,
  "weight_decay": 0.1,
  "grad_clip": 1.0,
  "eval_interval": 300,
  "eval_steps": 40,
  "log_interval": 25,
  "checkpoint_dir": "checkpoints/moe-small",
  "keep_last_checkpoints": 2,
  "device": "auto",
  "seed": 1337,
  "model": {
    "vocab_size": 2048,
    "dim": 256,
    "n_layers": 6,
    "n_heads": 8,
    "n_kv_heads": 4,
    "max_seq_len": 256,
    "n_experts": 8,
    "n_active_experts": 2,
    "n_shared_experts": 1,
    "expert_hidden_dim": 352,
    "moe_aux_loss_coef": 0.01,
    "qk_norm": true,
    "tie_embeddings": true
  }
}
